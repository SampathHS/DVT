    <worksheet name='4a'>
      <layout-options>
        <title>
          <formatted-text>
            <run>&lt;Sheet Name&gt; </run>
            <run fontcolor='#000000' fontname='Times New Roman'>Display a worksheet showing a calculated field created to calculate the difference between overall Sales and Profit. Make the calculated field to round off the Profit field to at least one decimal places.</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Sample - Superstore)' name='federated.1bux4gj12606yt1b0mlsu155lyqo' />
          </datasources>
          <datasource-dependencies datasource='federated.1bux4gj12606yt1b0mlsu155lyqo'>
            <column caption='sales vs profit' datatype='real' name='[Calculation_0343199404089345]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Sales])-ROUND(SUM([Profit]), 1)' />
            </column>
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0343199404089345]' derivation='User' name='[usr:Calculation_0343199404089345:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <text column='[federated.1bux4gj12606yt1b0mlsu155lyqo].[usr:Calculation_0343199404089345:qk]' />
